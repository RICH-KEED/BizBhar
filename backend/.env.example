# Copy to backend/.env and fill in. Run the API from backend/ so Dotenv loads this file.
# Do not commit .env.

# --- PostgreSQL (e.g. Neon) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_HOST/YOUR_DB?sslmode=require
SPRING_DATASOURCE_USERNAME=your_user
SPRING_DATASOURCE_PASSWORD=your_password

# --- JWT (long random string in production) ---
JWT_SECRET=your-jwt-signing-secret-at-least-32-chars

# --- Stripe (Test mode) ---
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook: stripe listen --forward-to http://localhost:8081/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_secret_from_stripe_cli

# Optional: BIZBHAR_SEED_ENABLED=false skips demo catalog seed
